# Copy this file to `.env` in the same folder (involvex/ai-agent/.env).
# The extension reads it at runtime when loaded unpacked, so you don't have to
# type the token into Settings. `.env` is gitignored and never committed.

# GitHub Personal Access Token with ONLY the `gist` scope.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx

# Optional: reuse an existing backup Gist. Leave empty to create one on first backup.
GIST_ID=
